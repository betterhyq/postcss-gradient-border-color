{
  "name": "postcss-gradient-border-color",
  "version": "1.0.0-beta.4",
  "private": false,
  "description": "A PostCSS plugin that enables gradient colors for border-color using CSS background-like syntax",
  "keywords": [
    "border",
    "border-color",
    "css",
    "gradient",
    "linear-gradient",
    "postcss",
    "postcss-plugin"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@changesets/cli": "2.31.0",
    "@types/node": "25.6.0",
    "bumpp": "11.0.1",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "publint": "0.3.18",
    "tsdown": "0.21.9",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "postcss": "^8.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
