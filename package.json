{
  "name": "postcss-gradient-border-color",
  "version": "0.1.0",
  "private": false,
  "description": "A PostCSS plugin that enables gradient colors for border-color using CSS background-like syntax",
  "keywords": [
    "postcss",
    "postcss-plugin",
    "gradient",
    "border",
    "border-color",
    "linear-gradient",
    "css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "tsdown": "latest",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "postcss": "^8.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
