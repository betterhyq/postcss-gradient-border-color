{
  "name": "postcss-gradient-border-color",
  "version": "0.0.1-alpha.2",
  "private": false,
  "description": "A PostCSS plugin that enables gradient colors for border-color using CSS background-like syntax",
  "keywords": [
    "border",
    "border-color",
    "css",
    "gradient",
    "linear-gradient",
    "postcss",
    "postcss-plugin"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "tsdown": "0.21.9",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "postcss": "^8.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
